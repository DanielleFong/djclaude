#!/bin/bash
# djclaude — Rane ONE-driven three-headed Claude rig in tmux.
#
#   djclaude               full: latest claude harness on YOUR SUB (sonnet+fable heads)
#   djfreshclaude          fresh: thin harness on YOUR SUB, level from FRESH_LEVEL
#   flags: --fresh (= djfreshclaude) --restart (rebuild running rig)
#
#   OPUS head is ALWAYS dustinfreshclaude on DUSTIN'S KEY (never your sub).
#
# Defaults (override in ~/.config/djclaude/config or env):
#   FRESH_LEVEL=bare       fresh level for djfreshclaude: bare (claude --bare via
#                          `dustinfreshclaude sub`) — other levels TBD
#   OPUS_MODE=fast         dustinfreshclaude mode for the opus head: lean|strip|fast|fit
#
# Panes: 0 OPUS(dustin) | 1 SONNET(sub) | 2 slack | 3 GPT5.5(codex) | 4 FABLE(sub) | 5 timeline
set -euo pipefail
HERE="$(cd "$(dirname "$(readlink -f "$0")")" && pwd)"
DFC="$HOME/.local/bin/dustinfreshclaude"
CLAUDE="$HOME/.local/bin/claude"
S=djclaude

FRESH_LEVEL="${FRESH_LEVEL:-}"; OPUS_MODE="${OPUS_MODE:-}"
[[ -f "$HOME/.config/djclaude/config" ]] && source "$HOME/.config/djclaude/config"
FRESH_LEVEL="${FRESH_LEVEL:-bare}"; OPUS_MODE="${OPUS_MODE:-fit}"

MODE=full; RESTART=0; QUARTET=0
[[ "$(basename "$0")" == "djfreshclaude" ]] && MODE=fresh
RIG=""
_prev=""
for a in "$@"; do case "$a" in
  --fresh)   MODE=fresh ;;
  --restart) RESTART=1 ;;
  --quartet) QUARTET=1 ;;
  --rig)     _prev=rig ;;
  *) if [[ "$_prev" == rig ]]; then RIG="$a"; _prev=""; else
       echo "usage: $(basename "$0") [--fresh] [--restart] [--quartet] [--rig NAME]" >&2; exit 1; fi ;;
esac; done

if [[ -z "$RIG" && "$RESTART" == 0 ]] && tmux has-session -t $S 2>/dev/null; then
  exec tmux attach -t $S
fi
# rigs attach-or-build their own session
if [[ -n "$RIG" && "$RESTART" == 0 ]] && tmux has-session -t "dj-$RIG" 2>/dev/null; then
  exec tmux attach -t "dj-$RIG"
fi

QO=" --append-system-prompt-file $HERE/ctx-opus.md"
QS=" --append-system-prompt-file $HERE/ctx-sonnet.md"
QF=" --append-system-prompt-file $HERE/ctx-fable.md"
SKIP="--dangerously-skip-permissions"
THIN="--strict-mcp-config --mcp-config /opt/freshclaude/empty-mcp.json $SKIP"

# Sub-billed heads (sonnet, fable): full vs fresh harness
if [[ "$MODE" == fresh ]]; then
  case "$FRESH_LEVEL" in
    bare) SONNET_CMD="env -u CLAUDECODE -u CLAUDE_CODE_ENTRYPOINT -u ANTHROPIC_API_KEY -u ANTHROPIC_AUTH_TOKEN $CLAUDE --model claude-sonnet-5 --effort low$QS $THIN"
          FABLE_CMD="env -u CLAUDECODE -u CLAUDE_CODE_ENTRYPOINT -u ANTHROPIC_API_KEY -u ANTHROPIC_AUTH_TOKEN $CLAUDE --model 'claude-fable-5[1m]'$QF $THIN" ;;
    *) echo "djclaude: unknown FRESH_LEVEL '$FRESH_LEVEL' (known: bare)" >&2; exit 1 ;;
  esac
else
  SONNET_CMD="$CLAUDE --model claude-sonnet-5 --effort low$QS $SKIP"
  FABLE_CMD="$CLAUDE --model 'claude-fable-5[1m]'$QF $SKIP"
fi
# Opus head: ALWAYS Dustin's key via dustinfreshclaude (never the sub)
OPUS_CMD="EFFORT=low $DFC $OPUS_MODE$QO $SKIP --append-system-prompt 'You are the OPUS head.'"

: # pre-flight: refresh sub OAuth token if expired (dustinfreshclaude sub fails closed)
EXP=$(security find-generic-password -s "Claude Code-credentials" -w 2>/dev/null | python3 -c 'import json,sys; print(json.load(sys.stdin)["claudeAiOauth"].get("expiresAt",0))' 2>/dev/null || echo 0)
if [[ "$EXP" -le "$(( $(date +%s) * 1000 ))" ]]; then
  echo "djclaude: sub token expired — refreshing..."
  "$CLAUDE" -p "ok" --model claude-sonnet-5 >/dev/null 2>&1 || echo "djclaude: refresh failed, sub heads may die" >&2
fi
: > "$HERE/slack.md"
# --rig NAME: variable booth — heads defined by ~/.config/djclaude/rigs/NAME.sh
if [[ -n "$RIG" ]]; then
  RIGF="$HOME/.config/djclaude/rigs/$RIG.sh"
  [[ -f "$RIGF" ]] || { echo "djclaude: no rig $RIGF"; exit 1; }
  source "$RIGF"
  S="dj-$RIG_TITLE"
  if [[ -z "${LEFT_SCROLL_BACKEND:-}" ]]; then
    if [[ "$LEFT_TYPE" == "codex" ]]; then
      LEFT_SCROLL_BACKEND="codex_app"
    else
      LEFT_SCROLL_BACKEND="tmux"
    fi
  fi
  if [[ -z "${RIGHT_SCROLL_BACKEND:-}" ]]; then
    if [[ "$RIGHT_TYPE" == "codex" ]]; then
      RIGHT_SCROLL_BACKEND="codex_app"
    else
      RIGHT_SCROLL_BACKEND="tmux"
    fi
  fi
  if [[ "$LEFT_SCROLL_BACKEND" == "codex_app" || "$RIGHT_SCROLL_BACKEND" == "codex_app" ]]; then
    "$HERE/build-codex-scroll.sh"
  fi
  tmux kill-session -t $S 2>/dev/null || true
  tmux new-session -d -s $S -x 220 -y 60 "$(LEFT_CMD_BUILDER)"
  tmux split-window -h -t $S:0.0 "$(RIGHT_CMD_BUILDER)"
  tmux split-window -v -f -l 5 -t $S:0 "cd $HERE && ./.venv/bin/python timeline.py"
  tmux set-option -t $S remain-on-exit on
  printf '{"%s":{"pane":"%s:0.0","type":"%s","scroll":"%s","title":"%s"},"%s":{"pane":"%s:0.1","type":"%s","scroll":"%s","title":"%s"}}' \
    "$LEFT_KEY" "$S" "$LEFT_TYPE" "$LEFT_SCROLL_BACKEND" "${LEFT_TITLE:-$LEFT_KEY}" \
    "$RIGHT_KEY" "$S" "$RIGHT_TYPE" "$RIGHT_SCROLL_BACKEND" "${RIGHT_TITLE:-$RIGHT_KEY}" > /tmp/dragons-layout.json
  pkill -f "$HERE/midi_daemon.py" 2>/dev/null || true
  "$HERE/.venv/bin/python" "$HERE/midi_daemon.py" > "$HERE/daemon.log" 2>&1 &
  echo $! > "$HERE/daemon.pid"
  echo "rig '$RIG_TITLE' up (session $S)"
  [[ -t 0 ]] && exec tmux attach -t $S
  exit 0
fi
tmux kill-session -t $S 2>/dev/null || true
tmux new-session -d -s $S -x 220 -y 60 "$OPUS_CMD"
if [[ "$QUARTET" == 1 ]]; then
  tmux split-window -h -t $S:0.0 "$SONNET_CMD"
  tmux split-window -h -t $S:0.1 "tail -f $HERE/slack.md"
  tmux split-window -h -t $S:0.2 "codex -a never -s workspace-write -c model_reasoning_effort=none"
  tmux split-window -h -t $S:0.3 "$FABLE_CMD"
  printf "{\"opus\":\"$S:0.0\",\"sonnet\":\"$S:0.1\",\"gpt\":\"$S:0.3\",\"fable\":\"$S:0.4\"}" > /tmp/dragons-layout.json
else
  tmux split-window -h -t $S:0.0 "$FABLE_CMD"
  printf "{\"opus\":\"$S:0.0\",\"fable\":\"$S:0.1\"}" > /tmp/dragons-layout.json
fi
tmux select-layout -t $S:0 even-horizontal
tmux split-window -v -f -l 5 -t $S:0 "cd $HERE && ./.venv/bin/python timeline.py"
tmux set-option -t $S remain-on-exit on
( sleep 15
  tmux send-keys -t $S:0.0 "/config thinking=false" Enter   # opus: hard-off thinking
  [[ "$QUARTET" == 1 ]] && { sleep 1; tmux send-keys -t $S:0.1 "/config thinking=false" Enter; }
  sleep 2; tmux send-keys -t $S:0.0 "/fast on" Enter   # CC 2.1.202+: direct syntax
) &
pkill -f "$HERE/midi_daemon.py" 2>/dev/null || true
"$HERE/.venv/bin/python" "$HERE/midi_daemon.py" > "$HERE/daemon.log" 2>&1 &
echo $! > "$HERE/daemon.pid"
echo "djclaude up (daemon pid $(cat "$HERE/daemon.pid"))"
[[ -t 0 ]] && exec tmux attach -t $S
